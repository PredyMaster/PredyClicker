---
import Layout from "../layouts/Layout.astro"
import Input from "../components/ui/Input.astro"
import Button from "../components/ui/Button.astro"
---

<Layout title="Login - Predy Clicker">
	<main
		class="flex-1 flex flex-col bg-slate-950 min-h-screen pb-24 relative overflow-hidden p-14"
	>
		<!-- Background Effects -->
		<div
			class="absolute top-0 left-0 w-full h-full overflow-hidden -z-10 pointer-events-none"
		>
			<div
				class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-yellow-500/10 rounded-full blur-[100px]"
			>
			</div>
			<div
				class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-purple-500/10 rounded-full blur-[100px]"
			>
			</div>
		</div>

		<div class="w-full flex flex-col gap-8">
			<!-- Header -->
			<div class="text-center space-y-2">
				<h1
					class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-yellow-200 to-yellow-500 tracking-tight"
				>
					PREDY CLICKER
				</h1>
				<p class="text-slate-400">Bienvenido de nuevo</p>
			</div>

			<!-- Form -->
			<form
				id="loginForm"
				class="flex flex-col gap-6 bg-slate-900/40 p-6 rounded-2xl border border-slate-800/50 backdrop-blur-md shadow-xl"
			>
				<div class="space-y-4">
					<Input
						name="username"
						placeholder="Nombre de usuario"
						label="Usuario"
						required
					/>

					<div class="space-y-1">
						<Input
							type="password"
							name="password"
							placeholder="Contraseña"
							label="Contraseña"
							required
						/>
						<div class="flex justify-end">
							<a
								href="#"
								class="text-xs text-yellow-400/80 hover:text-yellow-400 transition-colors"
							>
								¿Olvidaste tu contraseña?
							</a>
						</div>
					</div>
				</div>

				<div class="pt-2">
					<Button type="submit" variant="primary"> Entrar </Button>
				</div>
			</form>

			<!-- Footer -->
			<div class="text-center">
				<p class="text-slate-400 text-sm">
					¿No tienes cuenta?
					<a
						href="/register"
						class="text-yellow-400 font-medium hover:text-yellow-300 transition-colors"
					>
						Regístrate
					</a>
				</p>
			</div>
		</div>
	</main>
</Layout>

<script>
	const loginForm = document.getElementById("loginForm") as HTMLFormElement

	loginForm?.addEventListener("submit", (e) => {
		e.preventDefault()
		const formData = new FormData(loginForm)
		const username = formData.get("username") as string
		const password = formData.get("password") as string

		if (username === "Predy" && password === "Master") {
			// Success
			window.location.href = "/profile"
		} else {
			// Error
			alert("Usuario o contraseña incorrectos (Prueba: Predy / Master)")
		}
	})
</script>
